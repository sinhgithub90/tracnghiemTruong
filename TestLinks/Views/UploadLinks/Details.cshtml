@model TestLinks.Models.UploadLink

@{
    ViewData["Title"] = "Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var routeDatas = new Dictionary<string, string> () {
        { "searchString", $"{ViewData["searchString"]}"},
        { "pageIndex", $"{ViewData["pageIndex"]}"}        
    };

}

<h1>Chi tiết</h1>

<div>
    <div>
        @if (User.IsInRole(Constants.RoleAdmin))
        {
             <a asp-action="Edit" asp-route-id="@Model.Id" class="mr-3">
                <i class="" data-feather="edit"></i>  Sửa
            </a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="text-danger mr-3">
                <i data-feather="delete"></i> Xóa
            </a>
        }
        <a class="mr-3"
           href="@Url.Action("Login", "UploadTests", new { id = Model.Id })" target="_blank">
            <i data-feather="link"></i> Link
        </a>
        <a asp-action="DownloadFiles" asp-route-id="@Model.Id" class="mr-3">
            <i data-feather="download"></i> Tải files
        </a>
    </div>

    <hr />

    <div class="row">
        <div class="col-md-6">
            <dl class="row">
                <dt class="col-sm-4">
                    @Html.DisplayNameFor(model => model.Description)
                </dt>
                <dd class="col-sm-8">
                    @Html.DisplayFor(model => model.Description)
                </dd>
                <dt class="col-sm-4">
                    @Html.DisplayNameFor(model => model.TimeOpen)
                </dt>
                <dd class="col-sm-8">
                    @Html.DisplayFor(model => model.TimeOpen)
                </dd>
                <dt class="col-sm-4">
                    @Html.DisplayNameFor(model => model.TimeClose)
                </dt>
                <dd class="col-sm-8">
                    @Html.DisplayFor(model => model.TimeClose)
                </dd>
                <dt class="col-sm-4">
                    @Html.DisplayNameFor(model => model.CourseId)
                </dt>
                <dd class="col-sm-8">
                    @Html.DisplayFor(model => model.CourseId)
                </dd>
                <dt class="col-sm-4">
                    @Html.DisplayNameFor(model => model.CourseYear)
                </dt>
                <dd class="col-sm-8">
                    @Html.DisplayFor(model => model.CourseYear)
                </dd>
            </dl>
        </div>

        <div class="col-md-6 ">
            <dl class="row">
                <dt class="col-sm-4">
                    @Html.DisplayNameFor(model => model.CourseTerm)
                </dt>
                <dd class="col-sm-8">
                    @Html.DisplayFor(model => model.CourseTerm)
                </dd>
                <dt class="col-sm-4">
                    @Html.DisplayNameFor(model => model.Password)
                </dt>
                <dd class="col-sm-8">
                    @Html.DisplayFor(model => model.Password)
                </dd>
                <dt class="col-sm-4">
                    @Html.DisplayNameFor(model => model.MaxFileSize)
                </dt>
                <dd class="col-sm-8">
                    @Html.DisplayFor(model => model.MaxFileSize)
                </dd>
                <dt class="col-sm-4">
                    @Html.DisplayNameFor(model => model.MaxFiles)
                </dt>
                <dd class="col-sm-8">
                    @Html.DisplayFor(model => model.MaxFiles)
                </dd>
                <dt class="col-sm-4">
                    @Html.DisplayNameFor(model => model.AlllowFileTypes)
                </dt>
                <dd class="col-sm-8">
                    @Html.DisplayFor(model => model.AlllowFileTypes)
                </dd>
            </dl>
        </div>
    </div>
</div>

<h4>Danh sách nộp bài (tổng số: @Model.UploadInfos.Count)</h4>
<a class="btn-primary btn" asp-action="UpdateStats" asp-route-id="@Model.Id">Cập nhật</a>
<hr />
<table class="table table-border table-striped">
    <thead class="thead-dark">
        <tr>
            <th>STT</th>
            <th>Mã thí sinh</th>
            <th>Số file</th>
            <th>Đăng nhập</th>
            @*<th>Nộp bài</th>*@
        </tr>
    </thead>
    <tbody>
        @{
            var infos = Model.UploadInfos.OrderBy(e => e.FileCount)
                .ThenBy(e => e.StudentId);
            int count = 0;
        }
        @foreach (var info in infos)
        {
            string color;
            if (info.FileCount == 0)
            {
                 color = "table-warning";
            }
            else if (info.Checked)
            {
                color = "table-success";
            }
            else
            {
                color = "";
            }
            count++;
            <tr class="@color">
                <td>@count</td>
                <td> @info.StudentId</td>
                <td>@info.FileCount</td>
                <td>
                    @if (info.LastLogin.Year > 1)
                    {
                        @Html.DisplayFor(e => info.LastLogin)
                    }
                    <a class="float-right mr-3" 
                        onclick="showModal(@info.LinkId, '@info.StudentId', @info.Checked.ToString().ToLower())"
                    >
                         <i class="" data-feather="eye"></i>  Xem
                    </a>
                </td>
                @* <td>
                    @if (info.LastSubmit.Year > 1)
                    {
                    @Html.DisplayFor(e => info.LastSubmit)
                    }
                    </td>*@
            </tr>
        }
    </tbody>
</table>

<h4>Nộp bổ sung</h4>
<hr />
<partial name="_files" model="Model" />

<form method="post" enctype="multipart/form-data"
      asp-action="UploadFiles" asp-route-id="@Model.Id">
    <input type="hidden" name="ReturnUrl" value="/UploadLinks/Details/@Model.Id" />
    <div class="form-group">
        <div class="col-md-10">
            <input type="file" name="files" multiple />
        </div>
    </div>
    <div class="form-group">
        <div class="col-md-10 m">
            <input class="btn btn-secondary" type="submit" value="Upload" />
        </div>
    </div>
</form>

<div>
    <a asp-action="Index"
        asp-all-route-data="@routeDatas"   
    ><i data-feather="arrow-left"></i>Quay lại</a>
</div>


<!-- Modal -->
<div class="modal fade" id="viewer-modal" tabindex="-1" role="dialog">

  <div class="modal-dialog modal-dialog-centered modal-xl" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="viewer-modal-title">Modal title</h5>
            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
              
            </button>
            <button onclick="verify()" class="btn btn-link btn-sm btn btn-outline-secondary" id="verify-upload">
                Xác nhận đã kiểm tra
            </button>
            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
              <span aria-hidden="true">&times;</span>
            </button>
           
      </div>
      <div>
            <ul class="list-group" id="file-list"></ul>
        </div>
      <div class="modal-body" id="viewer">
            
      </div>
    </div>
  </div>
</div>

<script>
    var selection = null;
    var files = null;
    var _linkId;
    var _studentId;
    var _checked;

    function verify()
    {
        $.ajax({
            method: 'GET',
            url: `/UploadLinks/VerifyUpload?linkId=${_linkId}&&studentId=${_studentId}`,
            success: function() {
                window.location = window.location;
            }
        });
    }

    function showModal(linkId, studentId, checked)
    {
        _linkId = linkId;
        _studentId = studentId;
        _checked = checked;

        $('#viewer-modal-title').html(`${_checked ? '✅' : '❔'} MSSV: ${studentId} `);
        $('#viewer').html('Đang tải ...');
        // load upload files
        $.ajax({
            url: `/UploadLinks/GetUploadInfo?linkId=${linkId}&&studentId=${studentId}`,
            method: 'GET',
            success: function (res) {
                files = res;
                selection = files.length > 0 ? files[0] : null;
                populateContent();
            } 
        });
        $('#viewer-modal').modal({});
        // prepare content
    }

    function populateContent() {
        var lis = files.map(function (file) {
            var active = file === selection ? "active" : "";
            return `<button onClick="onSelect('${file.id}')"  
                        type="button" 
                        class="list-group-item list-group-item-action ${active}">
                        ${file.name} <span class="badge badge-primary badge-pill">${file.kb}kb</span>
                    </button>`;
        });
         $('#file-list').html(lis);
         updateModalContent(selection);
    }

    function onSelect(id) {
  
        selection = files.find(e => e.id === id);
        populateContent();
    }

    function updateModalContent(item)
    {
        // name, url, type
        var name = item.fileName;
        var type = item.ext.endsWith(".pdf") ? "pdf" : "image";
        var url = `/UploadLinks/GetFile/${item.id}`;

        if(type === 'image')
        {
            content = '<img style="width: 100%;" src="' + url + '"' + ' />'
        } 
        else if(type === 'pdf')
        {
            // width: 100%;
            content = '<iframe style="width: 100%; height: 70vh;" src="' + url + '" ></iframe>'
        }
    
        $('#viewer').html(content);
    }

    //function showModal(name, url, type)
    //{
    //    var content;
    //    if(type === 'image')
    //    {
    //        content = '<img style="width: 100%;" src="' + url + '"' + ' />'
    //    } 
    //    else if(type === 'pdf')
    //    {
    //        // width: 100%;
    
    //        content = '<iframe style="width: 100%; height: 80vh;" src="' + url + '" ></iframe>'
    //    }
    //    $('#viewer-modal-title').html(name);
    //    $('#viewer').html(content);
    //    $('#viewer-modal').modal({});
    //}
</script>